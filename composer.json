{
  "name": "dmp/rest-bundle",
  "license": "MIT",
  "type": "symfony-bundle",
  "description": "DMP Rest bundle",
  "require": {
    "php": "^8.4",
    "ext-json": "*",
    "symfony/framework-bundle": "^6.4|^7.4",
    "symfony/serializer": "^6.4|^7.4",
    "symfony/property-access": "^6.4|^7.4",
    "symfony/property-info": "^6.4|^7.4",
    "phpdocumentor/reflection-docblock": "^5.6",
    "phpstan/phpdoc-parser": "^2.0"
  },
  "require-dev": {
    "dmp/cg-lib": "^0.1.1",
    "doctrine/orm": "^3.6",
    "matthiasnoback/symfony-dependency-injection-test": "^6.3",
    "phpunit/phpunit": "^12.5",
    "symfony/browser-kit": "*",
    "symfony/console": "*",
    "symfony/messenger": "*",
    "symfony/http-kernel": "*",
    "symfony/validator": "*",
    "symfony/routing": "*",
    "symfony/dependency-injection": "*",
    "symfony/config": "*",
    "symfony/options-resolver": "*",
    "symfony/web-link": "*"
  },
  "autoload": {
    "psr-4": {
      "DMP\\RestBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DMP\\RestBundle\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test-cc": "phpunit coverage-html report/"
  },
  "extra": {
    "symfony": {
      "allow-contrib": true,
      "require": "^6.4|^7.4"
    }
  }
}
